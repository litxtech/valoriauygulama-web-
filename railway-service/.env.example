# Üretim (Hetzner): Supabase Edge secret KBS_GATEWAY_URL = http://YOUR_STATIC_IP:4000
# Bu dosyada GATEWAY_BASE_URL = http://127.0.0.1:4001 (PM2 ecosystem ile); dış IP buraya yazılmaz.
PORT=4000
APP_ENV=prod
LOG_LEVEL=info

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# İç KBS HTTP gateway (SOAP) — Ops API’den ayrı süreç; aynı VPS’te farklı port (örn. 4001).
# Boş bırakılırsa aşağıdaki yedek isimlerden biri okunur: KBS_SOAP_GATEWAY_URL veya INTERNAL_KBS_GATEWAY_URL
GATEWAY_BASE_URL=http://127.0.0.1:4001
# KBS_SOAP_GATEWAY_URL=http://127.0.0.1:4001
# INTERNAL_KBS_GATEWAY_URL=http://127.0.0.1:4001
GATEWAY_SHARED_SECRET=change-me-please-change-me

# Encryption key used to encrypt/decrypt ops.hotel_kbs_credentials.*_encrypted
KBS_CREDENTIAL_SECRET=change-me-please-change-me

# Supabase Edge ops-proxy ile aynı (üretimde zorunlu önerilir); boşsa başlık kontrolü yapılmaz
KBS_GATEWAY_TOKEN=

