# Supabase - Kendi değerlerinizle doldurun
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Mobil (Expo) ---
# KBS UI: false/eksik = personel KBS sekmesi + admin KBS menüleri gizli. true = göster.
# EXPO_PUBLIC_KBS_UI_ENABLED=true   (dikkat: EXPO_ ile başlar, EXO_ değil)
#
# KBS köprüsü: Supabase KBS_GATEWAY_URL = Railway ops URL (deploy/RAILWAY_KURULUM.md)
# EXPO_PUBLIC_RAILWAY_API_URL=https://....up.railway.app  (aynı kök, mobil referans)
#
# --- iOS/Android MRZ (development client — Expo Go çalışmaz) ---
# Gerekli native paketler package.json'da: vision-camera, vision-camera-mlkit, worklets-core
# Yerel (Mac): npx expo run:ios
# EAS iOS dev client: npm run build:dev:ios
# Kurulum sonrası: npm run start:dev
#
# KBS: lib/kbsApi → Supabase Edge `ops-proxy` → dış KBS API (mobil asla KBS URL’si tutmaz).
#
# --- Supabase Edge (Dashboard → Edge Functions → Secrets) ---
# KBS_GATEWAY_URL=https://valoriahotel-production.up.railway.app
# KBS_GATEWAY_TOKEN=<Railway kbs-ops ile aynı; x-kbs-gateway-token>
#
# --- Railway (kbs-ops + kbs-core) — deploy/RAILWAY_KURULUM.md ---
# KBS_GATEWAY_TOKEN, GATEWAY_SHARED_SECRET, KBS_CREDENTIAL_SECRET, SUPABASE_* → Railway Variables
# kbs-ops: GATEWAY_BASE_URL = kbs-core public URL
#
# --- kbs-gateway (Railway servis: kbs-core) ---
# OFFICIAL_PROVIDER_MODE=http
# OFFICIAL_PROVIDER_BASE_URL=https://vatandas.jandarma.gov.tr/KBS_Tesis_Servis/SrvShsYtkTml.svc
#
# --- İlk KBS kimlik kaydı (opsiyonel CLI; admin panelden de yapılabilir) ---
# KBS_SEED_FACILITY_CODE=255579
# KBS_SEED_PASSWORD=<KBS otel web servis şifresi>
# KBS_SEED_KULLANICI_TC=<11 haneli KBS kullanıcı TC>
# node scripts/seed-kbs-credentials.js

# Canlı web sitesi (QR: /menü/slug, /sözleşme, /maliye). Vercel’de valoria.tr domain ekleyin.
EXPO_PUBLIC_APP_URL=https://valoria.tr
# Varsayılan menü slug (anasayfa Menü butonu): /menu/{slug}
EXPO_PUBLIC_PUBLIC_MENU_ORG_SLUG=valoria

# Sözleşme onay sayfası URL’si. Boş bırakırsanız Supabase sayfası kullanılır.
# Temiz URL için (valoria.app/sozlesme): valoria.app’te docs/valoria-app-sozlesme-page.html’i /sozlesme path’ine koyun, sonra:
# EXPO_PUBLIC_PUBLIC_CONTRACT_URL=https://valoriahotel-el4r.vercel.app/guest/sign-one

# Publishable key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Access token (giriş / bağlantı)
SUPABASE_ACCESS_TOKEN=your-access-token

# Konum bildirimi (geofence) – otel koordinatları
# EXPO_PUBLIC_HOTEL_LAT=41.0082
# EXPO_PUBLIC_HOTEL_LON=28.9784

# Mapbox (harita) – sadece pk. (public) token; sk. sadece sunucu tarafında
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ...

# --- Stripe (QR ödeme — Checkout Session) ---
# Secret key ASLA repoya veya Expo client'a yazılmaz. Yalnızca Supabase Edge secrets:
#   STRIPE_SECRET_KEY=sk_test_... veya sk_live_...
#   STRIPE_WEBHOOK_SECRET=whsec_...   (Stripe Dashboard → Webhooks → signing secret)
#   STRIPE_DEFAULT_CURRENCY=try   (sadece varsayılan; personel ekranında TRY/USD/EUR/SAR seçilir)
# Stripe Dashboard → Settings → Payments → para birimlerini açın: TRY, USD, EUR, SAR
#   PAYMENT_SUCCESS_URL=https://valoria.tr/odeme/basarili?token={token}   (opsiyonel; kapalı S3/CloudFront Access Denied verir!)
#   PAYMENT_CANCEL_URL=...   (opsiyonel)
#   Varsayılan: SUPABASE_URL/functions/v1/payment-return (önerilen)
#   PAYMENT_APP_SCHEME=valoria   (dönüş sayfasındaki deep link)
#   PAYMENT_BRAND_OG_IMAGE_URL=https://.../valoria-og.png   (WhatsApp/link önizleme görseli, opsiyonel)
#   PAYMENT_PUBLIC_BASE_URL=https://valoria.tr   (paylaşılan link — Supabase URL yerine; Vercel /odeme proxy gerekir)
#   Supabase Edge secrets (create-payment-request vb.): PAYMENT_PUBLIC_BASE_URL=https://valoria.tr
#   PAYMENT_CANCEL_URL=https://valoria.tr/odeme/iptal?token={token}       (opsiyonel)
# Publishable key (pk_) şu an QR akışında zorunlu değil; ileride uygulama içi kart için:
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... veya pk_live_...
# Deploy: supabase functions deploy create-payment-request stripe-webhook
