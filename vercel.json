{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/kbs",
      "destination": "/kbs/index.html"
    },
    {
      "source": "/kbs/",
      "destination": "/kbs/index.html"
    },
    {
      "source": "/maliye/index.html",
      "destination": "/maliye/index.html"
    },
    {
      "source": "/maliye",
      "destination": "/maliye/index.html"
    },
    {
      "source": "/maliye/",
      "destination": "/maliye/index.html"
    },
    {
      "source": "/payment/qr/",
      "destination": "/api/payment/qr"
    },
    {
      "source": "/payment/qr",
      "destination": "/api/payment/qr"
    },
    {
      "source": "/payment/",
      "destination": "/api/payment"
    },
    {
      "source": "/payment",
      "destination": "/api/payment"
    },
    {
      "source": "/odeme/qr/",
      "destination": "/api/odeme/qr"
    },
    {
      "source": "/odeme/qr",
      "destination": "/api/odeme/qr"
    },
    {
      "source": "/odeme/",
      "destination": "/api/odeme"
    },
    {
      "source": "/odeme",
      "destination": "/api/odeme"
    },
    {
      "source": "/breakfast-pass/",
      "destination": "/breakfast-pass/index.html"
    },
    {
      "source": "/breakfast-pass",
      "destination": "/breakfast-pass/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/menu/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/((?!_expo|assets|maliye|favicon|breakfast-pass).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/maliye/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/maliye-config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/breakfast-pass-config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ]
}
