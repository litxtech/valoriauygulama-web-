{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/maliye/index.html",
      "destination": "/maliye/index.html"
    },
    {
      "source": "/maliye",
      "destination": "/maliye/index.html"
    },
    {
      "source": "/maliye/",
      "destination": "/maliye/index.html"
    },
    {
      "source": "/odeme/qr",
      "destination": "/odeme/qr/index.html"
    },
    {
      "source": "/odeme",
      "destination": "/odeme/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/menu/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/((?!_expo|assets|maliye|favicon).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/maliye/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/maliye-config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ]
}
